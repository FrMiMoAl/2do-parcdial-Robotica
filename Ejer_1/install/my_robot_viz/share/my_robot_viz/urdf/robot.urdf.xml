<!-- urdf/robot.urdf.xml -->
<?xml version="1.0"?>
<robot name="esp32_robot">

  <!-- BASE -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.03"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.20 0.15 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="0.20 0.15 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- RUEDA IZQUIERDA -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0 0.09 -0.02" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <!-- RUEDA DERECHA -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0 -0.09 -0.02" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <!-- IMU FRAME -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0.03"/>
  </joint>

  <link name="imu_link"/>

</robot>